# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (sensitive data)
.env
.env.local
.env.production
.env.staging
.env.*.local

# Git and version control
.git/
.gitignore
.github/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# MacOS files
.DS_Store
.AppleDouble
.LSOverride

# Logs and temporary files
*.log
logs/
tmp/
temp/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Docker files (avoid recursion)
Dockerfile
.dockerignore
docker-compose.yml

# Documentation and README files (not needed in container)
*.md
docs/

# Test files and coverage
test/
tests/
coverage/
.nyc_output

# Build artifacts
dist/
build/
.cache/

# Package manager lock files (we use npm ci, so package-lock.json is needed)
# yarn.lock
# pnpm-lock.yaml

# OS generated files
Thumbs.db
ehthumbs.db

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env.test

# parcel-bundler cache (https://parceljs.org/)
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out